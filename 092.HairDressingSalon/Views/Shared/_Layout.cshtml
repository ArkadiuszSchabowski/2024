<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]Salon fryzjerski - Asia</title>
    <link rel="stylesheet" href="~/css/globalSite.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/mainContent.css" asp-append-version="true" />
</head>
<body>
    <header>
        <div id="registration">Rejestracja</div>
        <div id="login">Logowanie</div>
        <div id="booking">Rezerwacja</div>
        <div id="priceList">Oferta</div>
        <div id="contact">Kontakt</div>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer>
        <div id="contactDetails"></div>
        <p>Dane kontaktowe:</p>
        <p>Asia Salon</p>
        <p>ul. Azjatycka 5</p>
        <p>41-506 Chorzów</p>

        <p>Telefon: +48 500 000 000</p>
        <p>arkadiuszschabowski@gmail.com</p>
        <p>www.github.com</p>

        <div id="Opening Hours">
            <p>Poniedziałek: 10:00 - 21:00</p>
            <p>Wtorek: 10:00 - 21:00</p>
            <p>Środa: 10:00 - 21:00</p>
            <p>Czwartek: 10:00 - 21:00</p>
            <p>Piątek: 10:00 - 21:00</p>
            <p>Sobota: 10:00 - 19:00</p>
            <p>Niedziela: Nieczynne</p>
        </div>
    </footer>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
